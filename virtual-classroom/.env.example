# Flask Configuration
FLASK_SECRET_KEY=your-super-secret-key-change-me

# AWS RDS / MySQL Database Configuration
# If host, user, and password are set, the app will connect to MySQL. Otherwise, it defaults to SQLite local database.
DB_HOST=your-rds-endpoint.amazonaws.com
DB_USER=admin
DB_PASSWORD=yourpassword
DB_NAME=virtual_classroom
DB_PORT=3306

# AWS S3 Storage Configuration
# If AWS keys and bucket are set, the app will upload materials to S3. Otherwise, it defaults to local file uploads.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-classroom-materials-bucket
